{
  "name": "art-archive-node",
  "version": "1.0.0",
  "description": "Node.js Express backend with MVC architecture, PostgreSQL and Sequelize ORM",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --watch . --ext ts,js --exec \"node --loader ts-node/esm ./server.ts\"",
    "build": "tsc -p .",
    "typeorm:generate": "tsc -p . && npx typeorm migration:generate ./dist/migrations/init --outputJs --dataSource ./dist/data-source.js",
    "typeorm:run": "npx typeorm migration:run --dataSource ./dist/data-source.js"
  },
  "keywords": [
    "express",
    "nodejs",
    "mvc",
    "postgresql",
    "sequelize"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/s3-request-presigner": "^3.1063.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "iran-city": "^1.2.2",
    "jsonwebtoken": "^9.0.2",
    "kavenegar": "^1.1.4",
    "melipayamak": "^1.0.0",
    "melipayamak-api": "^0.1.0",
    "mime-types": "^3.0.2",
    "minio": "^8.0.6",
    "monopay": "^2.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "pg": "^8.11.3",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/kavenegar": "^1.1.3",
    "@types/morgan": "^1.9.4",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.9.2",
    "nodemon": "^3.0.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}
